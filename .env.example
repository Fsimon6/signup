FEISHU_TAB_NUMBER=1
SF_TAB_NUMBER=2

QUERY_DELAY_SECONDS=2
SF_RESULT_WAIT_SECONDS=3.5
MAX_ROWS=0
SKIP_FILLED=true

# Selenium 配置
# SF_URL: 顺丰查询页面地址（必填）
SF_URL=
# SELENIUM_TIMEOUT: 元素等待超时时间（秒）
SELENIUM_TIMEOUT=10
# CHROME_USER_DATA_DIR: Chrome 用户数据目录（可选，用于保持登录状态）
# 留空则每次需要手动登录；填写后可继承已有 Chrome 登录态
CHROME_USER_DATA_DIR=
